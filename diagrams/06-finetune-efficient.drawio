<mxfile host="app.diagrams.net">
  <diagram name="finetune-efficient" id="finetune-efficient">
    <mxGraphModel dx="960" dy="640" grid="1" gridSize="10" guides="1" page="1" pageWidth="1100" pageHeight="640" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Как адаптировать модель под задачу" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="330" y="20" width="440" height="30" as="geometry"/>
        </mxCell>

        <!-- FULL FINE-TUNING -->
        <mxCell id="full-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="230" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="full-t" value="Full fine-tuning&#10;(полное дообучение)" style="text;html=1;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="70" y="90" width="210" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="full-model" value="Обновляются&#10;ВСЕ веса модели" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="85" y="140" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="full-cost" value="Дорого: десятки ГБ VRAM,&#10;большой датасет,&#10;копия модели на диске" style="text;html=1;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="70" y="210" width="210" height="80" as="geometry"/>
        </mxCell>

        <!-- LoRA -->
        <mxCell id="lora-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="320" y="80" width="230" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="lora-t" value="LoRA / QLoRA" style="text;html=1;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="330" y="90" width="210" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="lora-frozen" value="База заморожена&#10;(не трогаем)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="345" y="130" width="180" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="lora-adapter" value="+ маленький адаптер&#10;(учим только его)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="345" y="188" width="180" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="lora-cost" value="Дёшево: ~0.1% параметров,&#10;адаптер в мегабайтах" style="text;html=1;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="330" y="245" width="210" height="45" as="geometry"/>
        </mxCell>

        <!-- QUANTIZATION -->
        <mxCell id="quant-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="580" y="80" width="230" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="quant-t" value="Квантизация" style="text;html=1;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="590" y="90" width="210" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="quant-bits" value="16 бит  →  8 / 4 бита" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="605" y="135" width="180" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="quant-cost" value="Модель в 2–4× легче&#10;и быстрее.&#10;Лёгкая потеря качества.&#10;→ запуск на слабом железе" style="text;html=1;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="590" y="200" width="210" height="90" as="geometry"/>
        </mxCell>

        <!-- DISTILLATION -->
        <mxCell id="dist-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="840" y="80" width="220" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="dist-t" value="Дистилляция" style="text;html=1;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="850" y="90" width="200" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="dist-teacher" value="Учитель (большая)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="875" y="130" width="150" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="dist-student" value="Ученик (маленькая)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="890" y="210" width="120" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="dist-arrow" value="учит" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#d79b00;fontSize=11;" edge="1" parent="1" source="dist-teacher" target="dist-student">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="dist-cost" value="Отдельная компактная&#10;модель, дешёвый инференс" style="text;html=1;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="850" y="255" width="200" height="35" as="geometry"/>
        </mxCell>

        <!-- BOTTOM RULE -->
        <mxCell id="rule-box" value="Правило: чтобы добавить ЗНАНИЯ — сначала RAG или промптинг (веса не меняются).&#10;Обучение (LoRA / DPO) нужно, чтобы поменять ПОВЕДЕНИЕ, стиль или формат." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="180" y="360" width="740" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="axis" value="LoRA — добавляет умение · Квантизация — сжимает представление · Дистилляция — уменьшает саму модель" style="text;html=1;fontSize=11;fontStyle=2;align=center;" vertex="1" parent="1">
          <mxGeometry x="120" y="320" width="860" height="30" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

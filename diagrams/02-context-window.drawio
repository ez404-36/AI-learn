<mxfile host="app.diagrams.net">
  <diagram name="context-window" id="context-window">
    <mxGraphModel dx="800" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="600" pageHeight="560" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Что помещается в один запрос" style="text;html=1;fontSize=16;fontStyle=1;align=center;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="120" y="20" width="360" height="30" as="geometry" />
        </mxCell>
        <mxCell id="window" value="Контекстное окно (напр. 128k токенов)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="60" y="70" width="480" height="320" as="geometry" />
        </mxCell>
        <mxCell id="sys" value="System prompt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6" vertex="1" parent="1">
          <mxGeometry x="100" y="110" width="400" height="50" as="geometry" />
        </mxCell>
        <mxCell id="hist" value="История диалога" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1">
          <mxGeometry x="100" y="170" width="400" height="50" as="geometry" />
        </mxCell>
        <mxCell id="docs" value="Документы (RAG)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00" vertex="1" parent="1">
          <mxGeometry x="100" y="230" width="400" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ans" value="Ответ модели" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="1">
          <mxGeometry x="100" y="290" width="400" height="50" as="geometry" />
        </mxCell>
        <mxCell id="out" value="Вышло за окно → модель НЕ помнит" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=2;opacity=60" vertex="1" parent="1">
          <mxGeometry x="100" y="420" width="400" height="50" as="geometry" />

<mxfile host="app.diagrams.net">
  <diagram name="Full RAG Pipeline" id="rag-full">
    <mxGraphModel dx="800" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Полный RAG-пайплайн" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="300" height="30" as="geometry" />
        </mxCell>
        <mxCell id="leftLbl" value="Индексация (заранее)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=13;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="220" height="30" as="geometry" />
        </mxCell>
        <mxCell id="rightLbl" value="Запрос (на каждый вопрос)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=13;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="620" y="70" width="240" height="30" as="geometry" />
        </mxCell>
        <mxCell id="docs" value="Документы" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1">

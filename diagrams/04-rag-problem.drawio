<mxfile host="app.diagrams.net">
  <diagram name="RAG Problem" id="rag-problem">
    <mxGraphModel dx="800" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="700" pageHeight="450" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Проблема: знаний много, контекст мал" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="120" y="20" width="460" height="30" as="geometry" />
        </mxCell>
        <mxCell id="docs" value="5000 страниц документации" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00" vertex="1" parent="1">
          <mxGeometry x="80" y="90" width="220" height="120" as="geometry" />
        </mxCell>
        <mxCell id="ctx" value="Контекстное окно" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450" vertex="1" parent="1">
          <mxGeometry x="450" y="120" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ft" value="Fine-tuning" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666" vertex="1" parent="1">
          <mxGeometry x="440" y="290" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e1" value="НЕ влезает" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block" edge="1" parent="1" source="docs" target="ctx">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="дорого / долго" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block" edge="1" parent="1" source="docs" target="ft">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

<mxfile host="app.diagrams.net">
  <diagram name="agent-safety" id="agent-safety">
    <mxGraphModel dx="1000" dy="640" grid="1" gridSize="10" guides="1" page="1" pageWidth="1120" pageHeight="560" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Слои защиты LLM-системы (defense in depth)" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="310" y="20" width="500" height="30" as="geometry"/>
        </mxCell>

        <!-- USER INPUT -->
        <mxCell id="user" value="Ввод&#10;пользователя" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="60" y="150" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- EXTERNAL DATA (injection source) -->
        <mxCell id="ext" value="Внешние данные&#10;(веб, RAG, документы)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="270" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="inject-label" value="точка prompt injection&#10;(особенно косвенной)" style="text;html=1;fontSize=11;fontStyle=2;align=center;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="30" y="335" width="180" height="30" as="geometry"/>
        </mxCell>

        <!-- GUARDRAIL IN -->
        <mxCell id="gin" value="GUARDRAILS&#10;на входе" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="260" y="180" width="120" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="gin-note" value="фильтр запрещённых&#10;запросов, попыток&#10;инъекции" style="text;html=1;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="255" y="302" width="130" height="45" as="geometry"/>
        </mxCell>

        <!-- MODEL -->
        <mxCell id="model" value="LLM / Агент&#10;&#10;alignment (RLHF/DPO)&#10;встроен в веса" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="450" y="170" width="200" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="jail-label" value="цель jailbreak:&#10;уговорить обойти alignment" style="text;html=1;fontSize=11;fontStyle=2;align=center;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="440" y="120" width="220" height="30" as="geometry"/>
        </mxCell>

        <!-- TOOLS with limited rights -->
        <mxCell id="tools" value="Инструменты&#10;(ограниченные права:&#10;read-only, подтверждение)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=middle;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="450" y="360" width="200" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="model-tools" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;startArrow=block;strokeColor=#d6b656;" edge="1" parent="1" source="model" target="tools"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- GUARDRAIL OUT -->
        <mxCell id="gout" value="GUARDRAILS&#10;на выходе" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="720" y="180" width="120" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="gout-note" value="блок утечек PII,&#10;токсичности,&#10;опасных команд" style="text;html=1;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="715" y="302" width="130" height="45" as="geometry"/>
        </mxCell>

        <!-- OUTPUT -->
        <mxCell id="out" value="Ответ&#10;пользователю" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="920" y="210" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- FLOW EDGES -->
        <mxCell id="e-user-gin" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#333333;" edge="1" parent="1" source="user" target="gin"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e-ext-gin" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#b85450;dashed=1;" edge="1" parent="1" source="ext" target="gin"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e-gin-model" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#333333;" edge="1" parent="1" source="gin" target="model"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e-model-gout" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#333333;" edge="1" parent="1" source="model" target="gout"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e-gout-out" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#333333;" edge="1" parent="1" source="gout" target="out"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- FOOTER -->
        <mxCell id="footer" value="Ни один слой не защищает в одиночку: alignment снижает вероятность, guardrails и ограничение прав снижают ущерб, evals дают обратную связь." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="140" y="470" width="840" height="50" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

<mxfile host="app.diagrams.net">
  <diagram name="ReLU" id="relu01">
    <mxGraphModel dx="800" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="560" pageHeight="460" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="График функции активации ReLU" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="100" y="20" width="360" height="30" as="geometry" />
        </mxCell>

        <mxCell id="xaxis" value="" style="endArrow=block;html=1;strokeColor=#666666;strokeWidth=2" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="80" y="320" as="sourcePoint" />
            <mxPoint x="500" y="320" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="yaxis" value="" style="endArrow=block;html=1;strokeColor=#666666;strokeWidth=2" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="290" y="400" as="sourcePoint" />
            <mxPoint x="290" y="90" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="xlabel" value="z (вход)" style="text;html=1;align=left;verticalAlign=middle;fontSize=13;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="500" y="326" width="60" height="20" as="geometry" />
        </mxCell>
        <mxCell id="ylabel" value="ReLU(z) (выход)" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="225" y="62" width="130" height="20" as="geometry" />
        </mxCell>
        <mxCell id="origin" value="0" style="text;html=1;align=center;verticalAlign=middle;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="272" y="324" width="16" height="18" as="geometry" />
        </mxCell>

        <mxCell id="flatline" value="" style="endArrow=none;html=1;strokeColor=#b85450;strokeWidth=3" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="100" y="320" as="sourcePoint" />
            <mxPoint x="290" y="320" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="ramp" value="" style="endArrow=none;html=1;strokeColor=#b85450;strokeWidth=3" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="290" y="320" as="sourcePoint" />
            <mxPoint x="470" y="140" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="note-left" value="z ≤ 0 → выход 0&#10;(нейрон «молчит»)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="95" y="350" width="170" height="50" as="geometry" />
        </mxCell>
        <mxCell id="note-right" value="z &gt; 0 → выход = z&#10;(прямая под 45°,&#10;нейрон «срабатывает»)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="350" y="150" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="e-right" style="endArrow=block;html=1;strokeColor=#82b366;dashed=1" edge="1" parent="1" source="note-right" target="ramp">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="400" y="230" as="targetPoint" />

<mxfile host="app.diagrams.net">
  <diagram name="evals" id="evals">
    <mxGraphModel dx="900" dy="600" grid="1" gridSize="10" guides="1" page="1" pageWidth="900" pageHeight="560" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Цикл эвалов: юнит-тесты для LLM-системы" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="230" y="20" width="440" height="30" as="geometry"/>
        </mxCell>

        <!-- DATASET -->
        <mxCell id="dataset" value="Набор задач&#10;(вход + ожидание)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="360" y="90" width="180" height="60" as="geometry"/>
        </mxCell>

        <!-- SYSTEM -->
        <mxCell id="system" value="Прогон LLM-системы&#10;(промпт / модель / RAG)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="620" y="230" width="200" height="70" as="geometry"/>
        </mxCell>

        <!-- SCORING -->
        <mxCell id="score" value="Оценка ответов" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;verticalAlign=top;align=center;" vertex="1" parent="1">
          <mxGeometry x="360" y="360" width="180" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="score-note" value="- точное совпадение&#10;- метрики (нашёлся ли&#10;  нужный документ)&#10;- LLM-as-a-judge" style="text;html=1;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="375" y="388" width="160" height="85" as="geometry"/>
        </mxCell>

        <!-- RESULT / DECISION -->
        <mxCell id="result" value="Стало лучше&#10;или хуже?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="80" y="225" width="180" height="80" as="geometry"/>
        </mxCell>

        <!-- EDGES: cycle -->
        <mxCell id="e1" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#333333;" edge="1" parent="1" source="dataset" target="system"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" value="ответы" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#333333;fontSize=11;" edge="1" parent="1" source="system" target="score"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" value="результат" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#333333;fontSize=11;" edge="1" parent="1" source="score" target="result"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" value="меняем систему&#10;и прогоняем снова" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#b85450;fontSize=11;" edge="1" parent="1" source="result" target="dataset"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- FOOTER -->
        <mxCell id="footer" value="Заводите эвалы ДО оптимизаций: иначе улучшение под один пример молча ломает десять других. Отдельный набор атак (инъекции, jailbreak) — эвалы на безопасность." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="120" y="500" width="700" height="50" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
